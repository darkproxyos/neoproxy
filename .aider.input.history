+  const [btnText, setBtnText] = useState('INIT_SESSION')
+  const [logs, setLogs] = useState<string[]>([])
+  const containerRef = useRef<HTMLDivElement>(null)
+  const canvasRef = useRef<HTMLCanvasElement>(null)
+
+  useEffect(() => {
+    // Check memory (localStorage)
+    if (typeof window !== 'undefined') {
+      const mem = localStorage.getItem('np_mem')
+      if (mem) {
+        setIsReturning(true)
+        const newIntegrity = (98 + Math.random() * 1.5).toFixed(2)
+        setIntegrity(newIntegrity)
+      } else {
+        localStorage.setItem('np_mem', Date.now().toString())
+      }
+    }
+
+    // Boot sequence
+    const t1 = setTimeout(() => setPhase(1), 800)
+    const t2 = setTimeout(() => setPhase(2), 2200)
+    const t3 = setTimeout(() => setPhase(3), 4500)
+    const t4 = setTimeout(() => setPhase(4), 6500)
+    const t5 = setTimeout(() => setPhase(5), 8500)
+
+    return () => { clearTimeout(t1); clearTimeout(t2); clearTimeout(t3); clearTimeout(t4); clearTimeout(t5) }
+  }, [])
+
+  // Matrix rain / noise background
+  useEffect(() => {
+    const canvas = canvasRef.current
+    if (!canvas) return
+    const ctx = canvas.getContext('2d')
+    if (!ctx) return
+
+    canvas.width = window.innerWidth
+    canvas.height = window.innerHeight
+    ctx.fillStyle = 'rgba(2, 4, 8, 0.05)'
+    ctx.font = '12px monospace'
+
+    const chars = '01アイウエオカキクケコ<>{}[]'.split('')
+    const columns = Math.floor(canvas.width / 14)
+    const drops: number[] = Array(columns).fill(1)
+
+    const draw = () => {
+      ctx.fillStyle = 'rgba(2, 4, 8, 0.05)'
+      ctx.fillRect(0, 0, canvas.width, canvas.height)
+      ctx.fillStyle = '#0a2a4a'
+      
+      for (let i = 0; i < drops.length; i++) {
+        const text = chars[Math.floor(Math.random() * chars.length)]
+        ctx.fillText(text, i * 14, drops[i] * 14)
+        if (drops[i] * 14 > canvas.height && Math.random() > 0.975) {
+          drops[i] = 0
+        }
+        drops[i]++
+      }
+    }
+
+    const interval = setInterval(draw, 50)
+    const handleResize = () => {
+      canvas.width = window.innerWidth
+      canvas.height = window.innerHeight
+    }
+    window.addEventListener('resize', handleResize)
+
+    return () => { clearInterval(interval); window.removeEventListener('resize', handleResize) }
+  }, [])
+
+  // Scroll logs
+  useEffect(() => {
+    const handleScroll = () => {
+      if (!containerRef.current) return
+      const scrollY = containerRef.current.scrollTop
+      const newLogs: string[] = []
+      
+      if (scrollY > 100 && !logs.includes('> archive mounted')) newLogs.push('> archive mounted')
+      if (scrollY > 300 && !logs.includes('> memory synchronized')) newLogs.push('> memory synchronized')
+      if (scrollY > 600 && !logs.includes('> relic catalog indexed')) newLogs.push('> relic catalog indexed')
+      if (scrollY > 900 && !logs.includes('> anomaly detected')) newLogs.push('> anomaly detected')
+      if (scrollY < 50 && logs.length > 0) setLogs([]) // Reset on top
+
+      if (newLogs.length > 0) setLogs(prev => [...prev, ...newLogs])
+    }
+
+    const el = containerRef.current
+    el?.addEventListener('scroll', handleScroll)
+    return () => el?.removeEventListener('scroll', handleScroll)
+  }, [logs])
+
+  const handleAccess = () => {
+    setBtnText('ACCESS GRANTED')
+    setTimeout(() => router.push('/portal'), 600)
+  }
+
+  return (
+    <html lang="en">
