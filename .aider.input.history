+      </p>
+
+      <div style={{ marginTop: '3rem', display: 'grid', gridTemplateColumns: 'repeat(auto-fill, minmax(280px, 1fr))', gap: '20px' }}>
+        <div style={{ border: '1px solid #0a1a2a', padding: '24px' }}>
+          <p style={{ color: '#00ff9d', fontSize: '10px', letterSpacing: '2px' }}>EXTRACTION_CYCLE_01</p>
+          <h3 style={{ fontSize: '14px', marginTop: '12px', color: '#4a6080' }}>NP-RING-01</h3>
+          <p style={{ color: '#1a3a5c', fontSize: '12px', marginTop: '12px', lineHeight: '1.7' }}>
+            Proxy Mask Mk-I geometry translated to physical resin. Carries unique seed hash.
+          </p>
+          <Link href="/shop/drop01" style={{ color: '#0a4a6a', fontSize: '10px', textDecoration: 'none', display: 'inline-block', marginTop: '20px', borderBottom: '1px solid #0a2a4a' }}>
+            INSPECT →
+          </Link>
+        </div>
+
+        <div style={{ border: '1px solid #0a1a2a', padding: '24px', opacity: 0.4 }}>
+          <p style={{ color: '#1a3a5c', fontSize: '10px', letterSpacing: '2px' }}>PENDING</p>
+          <h3 style={{ fontSize: '14px', marginTop: '12px', color: '#4a6080' }}>NP-CORE-NODE</h3>
+          <p style={{ color: '#1a3a5c', fontSize: '12px', marginTop: '12px', lineHeight: '1.7' }}>
+            Physical synchronization interface. Awaiting Coherence Monitor clearance.
+          </p>
+          <span style={{ color: '#1a3a5c', fontSize: '10px', display: 'inline-block', marginTop: '20px' }}>[DORMANT — AWAITING PROTOCOL]</span>
+        </div>
+      </div>
+    </main>
+  )
+}
+NEOPROXY_EOF
+
+# Fix manifesto scroll
+sed -i 's/overflow: hidden/overflow-y: auto/g' app/manifesto/page.tsx
+
+# Safe text replacements for Shop and Drop01 (won't break 3D or checkout logic)
+sed -i 's/Shop/EXTRACTION_CHAMBER/g; s/Drop 01/EXTRACTION_CYCLE_01/g; s/Drop/EXTRACTION_CYCLE/g; s/Add to cart/INITIATE_EXTRACTION/g; s/Select size/SELECT_GEOMETRY_PARAM/g; s/Price/SIGNAL_COST/g; s/Buy/EXTRACT/g; s/product/artifact/g' app/shop/page.tsx app/shop/drop01/page.tsx
+
+echo "NEOPROXY REWRITE COMPLETE"
+```
+
+Después de pegar ese bloque, ejecutá:
+```bash
+npm run build
+```

